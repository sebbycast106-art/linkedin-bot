# ─────────────────────────────────────────────
# LINKEDIN-BOT — Environment Variables
# Copy this file to .env and fill in values
# Never commit .env to git
#
# WHY THIS EXISTS: When you clone this repo fresh or someone new joins, they
# know exactly what to set up. No more "why is production different from local?"
# ─────────────────────────────────────────────


# ── LinkedIn Credentials ──────────────────────────────────────────────────────

# [REQUIRED] Email address used to log into LinkedIn
LINKEDIN_EMAIL=you@example.com

# [REQUIRED] Password for the LinkedIn account
# Stored as a plain env var — keep this secret and never commit it
LINKEDIN_PASSWORD=your_linkedin_password_here


# ── Anthropic / Claude AI ─────────────────────────────────────────────────────

# [REQUIRED] Anthropic API key for Claude AI calls (job scoring, connection notes, etc.)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Telegram Notifications ────────────────────────────────────────────────────

# [REQUIRED] Telegram bot token — create a bot via @BotFather and copy the token
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIjKlMnOpQrStUvWxYz-xxxxxxxxxx

# [REQUIRED] Your Telegram user chat ID — the bot sends all alerts here
# Find yours by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=123456789


# ── Security ──────────────────────────────────────────────────────────────────

# [REQUIRED] Secret token that must be passed as ?secret= on all /internal/* endpoints
# This is what the dashboard and cron-job.org use to authenticate requests
# Generate: openssl rand -hex 32
# Must match SCHEDULER_SECRET and LINKEDIN_BOT_SECRET set in the dashboard environment
SCHEDULER_SECRET=your_scheduler_secret_here


# ── Storage ───────────────────────────────────────────────────────────────────

# [OPTIONAL] Directory where all bot state JSON files are persisted
# Defaults to /data (Railway volume mount path) if not set
# For local development, use an absolute path like: /tmp/linkedin-bot-data
DATA_DIR=/data
